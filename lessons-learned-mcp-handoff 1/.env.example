# ---------------------------------------------------------------------------
# Local development settings. Copy to `.env` and fill in.
# In Azure, these are supplied as Container App env vars / Key Vault references.
# ---------------------------------------------------------------------------

# Server
PORT=8080
NODE_ENV=development

# Provider seam ------------------------------------------------------------
# representative = seeded in-memory store (no external calls)
# jira           = real Jira Data Center provider (stub; customer completes)
PROVIDER_MODE=representative

# Endpoint auth ------------------------------------------------------------
# oauth  = validate Entra ID OAuth 2.0 bearer tokens (target)
# apikey = static header check (spike only; never for Option C)
AUTH_MODE=oauth

# OAuth (Entra ID) — required when AUTH_MODE=oauth
ENTRA_TENANT_ID=
MCP_API_CLIENT_ID=
# Audience the API expects in tokens, e.g. api://<MCP_API_CLIENT_ID>
MCP_API_AUDIENCE=

# API key — used only when AUTH_MODE=apikey
MCP_API_KEY=

# Public base URL used to advertise protected-resource metadata (RFC 9728).
# e.g. https://<containerapp-fqdn> or the APIM gateway URL in Option C.
PUBLIC_BASE_URL=http://localhost:8080

# Jira provider (consumed ONLY when PROVIDER_MODE=jira) — customer-provided
JIRA_BASE_URL=
JIRA_PROJECT_KEY=
# Injected from Key Vault in Azure; never commit a real value.
JIRA_PAT=

# Telemetry (optional) — enables Application Insights when set
APPLICATIONINSIGHTS_CONNECTION_STRING=
